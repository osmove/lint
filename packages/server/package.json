{
  "name": "@osmove/lint-server",
  "version": "0.1.0",
  "description": "Lint server — self-hosted backend for the Lint CLI (BUSL 1.1).",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lint-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.28.0",
    "tsup": "^8.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "author": "Jimmy Douieb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osmove/lint.git",
    "directory": "packages/server"
  },
  "homepage": "https://lint.to",
  "bugs": {
    "url": "https://github.com/osmove/lint/issues"
  },
  "keywords": [
    "lint",
    "linter",
    "self-hosted",
    "backend",
    "busl"
  ]
}
